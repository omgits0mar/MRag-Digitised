<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MRAG Evaluation Report</title>
<style>
  body { font-family: Arial, sans-serif; margin: 20px; max-width: 1100px; }
  table { border-collapse: collapse; margin: 10px 0; width: 100%; }
  th, td { padding: 8px 12px; text-align: left; border: 1px solid #ddd; }
  th { background-color: #f0f0f0; }
  .pass { color: green; font-weight: bold; }
  .regress { color: red; font-weight: bold; }
  img { max-width: 800px; margin: 10px 0; }
  h2 { margin-top: 30px; border-bottom: 2px solid #eee; padding-bottom: 5px; }
</style>
</head>
<body>
<h1>MRAG Evaluation Report</h1>
<p>Generated: {{ generated_at }} | Version: {{ mrag_version }} | Dataset: {{ dataset_name }}</p>

<h2>Retrieval Metrics</h2>
<table>
  <tr><th>Metric</th><th>Value</th></tr>
  <tr><td>MRR</td><td>{{ "%.4f" | format(retrieval.mrr) }}</td></tr>
  <tr><td>MAP</td><td>{{ "%.4f" | format(retrieval.map) }}</td></tr>
  {% for k, v in retrieval.precision_at_k.items() %}
  <tr><td>Precision@{{ k }}</td><td>{{ "%.4f" | format(v) }}</td></tr>
  {% endfor %}
  {% for k, v in retrieval.recall_at_k.items() %}
  <tr><td>Recall@{{ k }}</td><td>{{ "%.4f" | format(v) }}</td></tr>
  {% endfor %}
</table>
<img src="data:image/png;base64,{{ precision_vs_k_png }}" alt="Precision vs K">

<h2>Response Quality</h2>
<table>
  <tr><th>Metric</th><th>Value</th></tr>
  <tr><td>BLEU</td><td>{{ "%.4f" | format(response_quality.bleu) }}</td></tr>
  <tr><td>ROUGE-1</td><td>{{ "%.4f" | format(response_quality.rouge_1) }}</td></tr>
  <tr><td>ROUGE-2</td><td>{{ "%.4f" | format(response_quality.rouge_2) }}</td></tr>
  <tr><td>ROUGE-L</td><td>{{ "%.4f" | format(response_quality.rouge_l) }}</td></tr>
</table>
<img src="data:image/png;base64,{{ score_histogram_png }}" alt="Response Quality Scores">

<h2>Latency Benchmarks</h2>
<table>
  <tr><th>Percentile</th><th>Latency (ms)</th></tr>
  <tr><td>p50</td><td>{{ "%.1f" | format(benchmark.p50_ms) }}</td></tr>
  <tr><td>p95</td><td>{{ "%.1f" | format(benchmark.p95_ms) }}</td></tr>
  <tr><td>p99</td><td>{{ "%.1f" | format(benchmark.p99_ms) }}</td></tr>
  <tr><td>QPS</td><td>{{ "%.2f" | format(benchmark.qps) }}</td></tr>
</table>
<img src="data:image/png;base64,{{ latency_histogram_png }}" alt="Latency Distribution">

{% if baseline_comparison %}
<h2>Baseline Comparison</h2>
<p>Threshold: {{ "%.1f" | format(baseline_comparison.threshold_pct * 100) }}% | Has Regressions: {{ "Yes" if baseline_comparison.has_regressions else "No" }}</p>
<table>
  <tr><th>Metric</th><th>Baseline</th><th>Current</th><th>Delta %</th><th>Status</th></tr>
  {% for d in baseline_comparison.deltas %}
  <tr>
    <td>{{ d.metric }}</td>
    <td>{{ "%.4f" | format(d.baseline_value) }}</td>
    <td>{{ "%.4f" | format(d.current_value) }}</td>
    <td>{{ "%.2f" | format(d.delta_pct * 100) }}%</td>
    <td class="{{ d.status | lower }}">{{ d.status }}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

</body>
</html>
