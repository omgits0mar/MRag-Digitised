# =============================================================================
# MRAG Configuration — Environment Variables
# =============================================================================
# Copy this file to .env and set your values.
# Precedence: Environment variable > .env file > default value
# All values are validated on startup. Invalid values raise aggregate errors.
# =============================================================================

# --- App ---------------------------------------------------------------------
# APP_NAME          str     default: "mrag"         Application name
# APP_VERSION       str     default: "0.1.0"        Application version
# DEBUG             bool    default: false           Enable debug mode
# LOG_LEVEL         str     default: "INFO"          DEBUG|INFO|WARNING|ERROR|CRITICAL
APP_NAME=mrag
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# --- Embedding ----------------------------------------------------------------
# EMBEDDING_MODEL_NAME      str   default: "paraphrase-multilingual-MiniLM-L12-v2"
# EMBEDDING_DIMENSION       int   default: 384       Must match model output dimension
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# --- Chunking -----------------------------------------------------------------
# CHUNK_SIZE        int     default: 512            Text chunk size in characters
# CHUNK_OVERLAP     int     default: 50             Overlap between adjacent chunks
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Retrieval ----------------------------------------------------------------
# TOP_K             int     default: 5              Number of results per query
# FAISS_INDEX_TYPE  str     default: "Flat"         Flat|IVF|HNSW
TOP_K=5
FAISS_INDEX_TYPE=Flat

# --- LLM ----------------------------------------------------------------------
# LLM_API_URL       str     default: "https://api.groq.com/openai/v1"
# LLM_API_KEY       str     REQUIRED                Groq API key (secret)
# LLM_MODEL_NAME    str     default: "llama3-8b-8192"
# LLM_TEMPERATURE   float   default: 0.1            Range: 0.0–2.0
# LLM_MAX_TOKENS    int     default: 1024
LLM_API_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=llama3-8b-8192
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# --- Database -----------------------------------------------------------------
# DATABASE_URL      str     default: "sqlite:///mrag.db"   SQLAlchemy URL (secret)
DATABASE_URL=sqlite:///mrag.db

# --- Cache --------------------------------------------------------------------
# CACHE_TTL_SECONDS int     default: 3600           Cache time-to-live
# CACHE_MAX_SIZE    int     default: 1000           Maximum cached entries
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# --- Paths --------------------------------------------------------------------
# DATA_DIR          str     default: "data"          Base data directory
# PROMPTS_DIR       str     default: "prompts/templates"  Prompt template directory
DATA_DIR=data
PROMPTS_DIR=prompts/templates

# --- File Upload Ingestion ----------------------------------------------------
# UPLOAD_DIR                     str    default: "data/uploads"
# UPLOAD_MAX_BYTES               int    default: 104857600 (100 MB)
# UPLOAD_ALLOWED_EXTENSIONS      list   default: ["csv","txt","pdf","md","docx"]
UPLOAD_DIR=data/uploads
UPLOAD_MAX_BYTES=104857600
UPLOAD_ALLOWED_EXTENSIONS=["csv","txt","pdf","md","docx"]
